# Token Trail local development settings
# Copy to .env for machine-specific overrides. Do not commit .env.

# Demo identity
DEMO_NAME=token-trail
DEMO_MODE=development

# Shared model list and default model selection.
# Direct environment variables below override matching values from this file.
TOKEN_TRAIL_MODEL_CONFIG_PATH=config/models.json

# Initial selected backend.
# Options:
# - scripted: prepared token traces; safest default and no model server required.
# - ollama: live local text generation through Ollama.
# - hf-trace: optional live token trace through the local HF trace server.
# - vllm: deferred OpenAI-compatible local model experiment.
TOKEN_TRAIL_BACKEND=hf-trace

# Current single-process scripted MVP service.
# Reserved Token Trail frontend/kiosk port from PORTS_AND_LOCAL_SERVICES.md.
TOKEN_TRAIL_HOST=127.0.0.1
TOKEN_TRAIL_PORT=3100

# Reserved future Token Trail backend/API port.
# Use this when the frontend and backend are split.
TOKEN_TRAIL_BACKEND_PORT=8100
TOKEN_TRAIL_BACKEND_URL=http://127.0.0.1:8100

# Shared local services reserved by the Open Day port map.
TOKEN_TRAIL_MODEL_ADAPTER_URL=http://127.0.0.1:8600
TOKEN_TRAIL_REPLAY_SERVICE_URL=http://127.0.0.1:8700

# Used when TOKEN_TRAIL_BACKEND=ollama.
# Ollama's default API port is reserved for the external Ollama runtime.
TOKEN_TRAIL_OLLAMA_BASE_URL=http://127.0.0.1:11434
TOKEN_TRAIL_OLLAMA_MODEL=qwen3:1.7b

# Runtime-selectable Ollama model options are loaded from TOKEN_TRAIL_MODEL_CONFIG_PATH.
# Set this to demo-safe models already installed on the machine, from `ollama list`.
# TOKEN_TRAIL_OLLAMA_MODELS=qwen3:1.7b,qwen3:4b

# Ollama generation settings.
# Qwen3 can spend a small token budget on internal reasoning before producing visible response text.
# These defaults prefer short, direct public-demo output.
TOKEN_TRAIL_OLLAMA_NUM_PREDICT=96
TOKEN_TRAIL_OLLAMA_TEMPERATURE=0.3
TOKEN_TRAIL_OLLAMA_TIMEOUT_SECONDS=45
TOKEN_TRAIL_OLLAMA_DISABLE_THINKING=true
TOKEN_TRAIL_OLLAMA_REASONING_RETRY_TOKENS=qwen3:4b=512
TOKEN_TRAIL_OLLAMA_WARMUP_ENABLED=true
TOKEN_TRAIL_OLLAMA_WARMUP_TIMEOUT_SECONDS=45
TOKEN_TRAIL_OLLAMA_KEEP_ALIVE=30m

# Used when TOKEN_TRAIL_BACKEND=hf-trace.
# Enable for local HF trace smoke testing after the local HF trace server is running.
# The HF trace server is expected to expose POST /api/trace on port 8600.
TOKEN_TRAIL_HF_TRACE_ENABLED=true
TOKEN_TRAIL_HF_TRACE_URL=http://127.0.0.1:8600/api/trace
TOKEN_TRAIL_HF_TRACE_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# Runtime-selectable HF trace model options are loaded from TOKEN_TRAIL_MODEL_CONFIG_PATH.
# TOKEN_TRAIL_HF_TRACE_MODEL is the initial/default HF trace model.
# TOKEN_TRAIL_HF_TRACE_MODELS=Qwen/Qwen2.5-1.5B-Instruct,Qwen/Qwen2.5-0.5B-Instruct

TOKEN_TRAIL_HF_TRACE_TOP_K=5
TOKEN_TRAIL_HF_TRACE_MAX_NEW_TOKENS=48
TOKEN_TRAIL_HF_TRACE_TEMPERATURE=0.3
TOKEN_TRAIL_HF_TRACE_TIMEOUT_SECONDS=20

# Used when TOKEN_TRAIL_BACKEND=vllm.
# vLLM commonly uses 8000 for its OpenAI-compatible server; Token Trail itself does not use 8000.
TOKEN_TRAIL_VLLM_BASE_URL=http://127.0.0.1:8000/v1
TOKEN_TRAIL_VLLM_MODEL=Qwen/Qwen3-4B

# Runtime-selectable vLLM model options are loaded from TOKEN_TRAIL_MODEL_CONFIG_PATH.
# Set this to the model names or local paths used when launching vLLM.
# TOKEN_TRAIL_VLLM_MODELS=Qwen/Qwen3-4B
