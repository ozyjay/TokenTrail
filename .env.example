# Token Trail local development settings
# Copy to .env for machine-specific overrides. Do not commit .env.

# Demo identity
DEMO_NAME=token-trail
DEMO_MODE=development

# Initial selected backend.
# Options:
# - scripted: prepared token traces; safest fallback and no model server required.
# - hf-trace: replayable live token trace through the local HF trace server.
TOKEN_TRAIL_BACKEND=hf-trace

# Current single-process demo service.
TOKEN_TRAIL_HOST=127.0.0.1
TOKEN_TRAIL_PORT=3100

# Reserved future Token Trail backend/API port.
# Use this when the frontend and backend are split.
TOKEN_TRAIL_BACKEND_PORT=8100
TOKEN_TRAIL_BACKEND_URL=http://127.0.0.1:8100

# Shared local services reserved by the Open Day port map.
TOKEN_TRAIL_MODEL_ADAPTER_URL=http://127.0.0.1:8600
TOKEN_TRAIL_REPLAY_SERVICE_URL=http://127.0.0.1:8700

# Used when TOKEN_TRAIL_BACKEND=hf-trace.
# scripts/run.ps1 starts the local HF trace server on port 8600 when this is true.
TOKEN_TRAIL_HF_TRACE_ENABLED=true
TOKEN_TRAIL_HF_TRACE_URL=http://127.0.0.1:8600/api/trace
TOKEN_TRAIL_HF_TRACE_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# Runtime-selectable HF trace model options are discovered from the local
# Hugging Face cache. TOKEN_TRAIL_HF_TRACE_MODEL is only a preferred initial
# model when it is already installed locally.

TOKEN_TRAIL_HF_TRACE_TOP_K=5
TOKEN_TRAIL_HF_TRACE_MAX_NEW_TOKENS=96
TOKEN_TRAIL_HF_TRACE_TEMPERATURE=0.3
TOKEN_TRAIL_HF_TRACE_TIMEOUT_SECONDS=20
TOKEN_TRAIL_HF_TRACE_WARMUP_TIMEOUT_SECONDS=180
