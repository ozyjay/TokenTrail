# Token Trail local development settings
# Copy to .env for machine-specific overrides. Do not commit .env.

# Demo identity
DEMO_NAME=token-trail
DEMO_MODE=development

# scripted | ollama | vllm
TOKEN_TRAIL_BACKEND=scripted

# Current single-process scripted MVP service.
# Reserved Token Trail frontend/kiosk port from PORTS_AND_LOCAL_SERVICES.md.
TOKEN_TRAIL_HOST=127.0.0.1
TOKEN_TRAIL_PORT=3100

# Reserved future Token Trail backend/API port.
# Use this when the frontend and backend are split.
TOKEN_TRAIL_BACKEND_PORT=8100
TOKEN_TRAIL_BACKEND_URL=http://127.0.0.1:8100

# Shared local services reserved by the Open Day port map.
TOKEN_TRAIL_MODEL_ADAPTER_URL=http://127.0.0.1:8600
TOKEN_TRAIL_REPLAY_SERVICE_URL=http://127.0.0.1:8700

# Used when TOKEN_TRAIL_BACKEND=ollama.
# Ollama's default API port is reserved for the external Ollama runtime.
TOKEN_TRAIL_OLLAMA_BASE_URL=http://127.0.0.1:11434
TOKEN_TRAIL_OLLAMA_MODEL=qwen3:4b

# Used when TOKEN_TRAIL_BACKEND=vllm.
# vLLM commonly uses 8000 for its OpenAI-compatible server; Token Trail itself does not use 8000.
TOKEN_TRAIL_VLLM_BASE_URL=http://127.0.0.1:8000/v1
TOKEN_TRAIL_VLLM_MODEL=Qwen/Qwen3-4B
